---
import { Badge, Button, Card, Flex, Heading, Text } from "@radix-ui/themes";

const trustPills = ["Windows first", "本地优先", "任务中心", "低打扰"];
const nearbySignals = ["文本选中", "文件拖拽", "当前报错", "悬停输入", "按住说话"];
const snapshots = [
  { label: "悬浮球入口", value: "近场承接当前任务" },
  { label: "治理主线", value: "授权、审计、恢复点" },
  { label: "正式结果", value: "delivery_result / artifact / citation" },
];
---

<section class="section-frame relative px-4 pb-18 pt-10 lg:px-0 lg:pb-28 lg:pt-18">
  <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.04fr)_minmax(22rem,0.96fr)]">
    <div>
      <div class="mb-5 flex flex-wrap gap-3">
        {trustPills.map((pill) => (
          <Badge color="cyan" variant="soft" radius="full">{pill}</Badge>
        ))}
      </div>

      <p class="text-sm font-medium tracking-[0.28em] text-cc-peach uppercase">桌面协作 Agent</p>
      <h1 class="mt-4 max-w-4xl font-display text-5xl leading-none font-semibold tracking-tight text-white sm:text-6xl lg:text-[5.4rem]">
        你的桌面协作 Agent，小小一只，始终贴着当前工作现场待命。
      </h1>
      <p class="site-section-copy mt-6 max-w-2xl sm:text-xl">
        CialloClaw 以悬浮球为默认入口，停留在桌面边缘。从你当前的页面、文件、文档、报错或便签里承接任务，先确认意图，再推进 Agent Loop，最后通过
        <code class="rounded bg-white/8 px-2 py-1 text-sm text-white">delivery_result</code>,
        <code class="rounded bg-white/8 px-2 py-1 text-sm text-white">artifact</code>
        和
        <code class="rounded bg-white/8 px-2 py-1 text-sm text-white">citation</code>
        正式交付结果。
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <Button asChild size="4" radius="full" highContrast>
          <a href="#download">下载 Windows 版本</a>
        </Button>
        <Button asChild size="4" radius="full" variant="soft">
          <a href="/docs">阅读文档</a>
        </Button>
        <Button asChild size="4" radius="full" variant="outline">
          <a href="https://github.com/1024XEngineer/CialloClaw">查看 GitHub</a>
        </Button>
      </div>

      <div class="mt-10 flex flex-wrap gap-3 text-sm text-white/56">
        <span>近场入口：</span>
        {nearbySignals.map((signal) => (
          <span class="rounded-full border border-white/8 bg-slate-950/45 px-3 py-1.5 text-white/76">{signal}</span>
        ))}
      </div>
    </div>

    <div class="relative">
      <Card className="site-soft-card relative overflow-hidden rounded-[2rem] !p-6 lg:!p-8">
        <div class="absolute inset-x-0 top-0 h-40 bg-linear-to-b from-cc-cyan/10 via-cc-violet/10 to-transparent"></div>

        <div class="relative flex items-start justify-between gap-4">
          <div>
            <p class="text-xs tracking-[0.28em] text-cc-cyan uppercase">近场承接</p>
            <h2 class="mt-3 font-display text-3xl font-semibold text-white">从悬浮球入口到正式交付</h2>
          </div>
          <div class="relative flex h-20 w-20 items-center justify-center rounded-full border border-white/16 bg-slate-950/60 shadow-cc-glow">
            <div class="h-12 w-12 rounded-full bg-linear-to-br from-cc-cyan via-white to-cc-violet"></div>
            <div class="absolute h-20 w-20 rounded-full border border-cc-cyan/30"></div>
          </div>
        </div>

        <div class="relative mt-8 grid gap-4">
          <div class="grid gap-4 sm:grid-cols-3">
            {snapshots.map((item) => (
              <div class="rounded-[1.5rem] border border-white/8 bg-white/6 p-4">
                <p class="text-xs tracking-[0.24em] text-white/56 uppercase">{item.label}</p>
                <p class="mt-3 text-sm leading-7 text-white/78">{item.value}</p>
              </div>
            ))}
          </div>

          <div class="rounded-[1.75rem] border border-white/10 bg-slate-950/58 p-5">
            <Flex direction="column" gap="3">
              <Badge color="mint" variant="soft" radius="full">任务主链路</Badge>
              <Heading size="4">input → task → run / step / event → delivery_result</Heading>
              <Text size="3" color="gray">先承接，再确认，再治理，再交付。官网可以可爱，但主链路必须说清楚。</Text>
            </Flex>
          </div>
        </div>
      </Card>
    </div>
  </div>
</section>
