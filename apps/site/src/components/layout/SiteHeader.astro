---
import { PRIMARY_NAV_ITEMS } from "@/lib/constants";
import { Button } from "@radix-ui/themes";

const pathname = Astro.url.pathname;
const onDocsPage = pathname.startsWith("/docs");

function resolveHref(href: string): string {
  if (!href.startsWith("#")) {
    return href;
  }

  return onDocsPage ? `/${href}` : href;
}
---

<header class="sticky top-0 z-30 border-b border-white/8 bg-[rgba(10,10,22,0.72)] backdrop-blur-2xl">
  <div class="section-frame flex items-center justify-between gap-4 px-4 py-4 lg:px-0">
    <a class="focus-ring inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/6 px-4 py-2.5 shadow-[0_18px_48px_-28px_rgba(255,122,162,0.6)]" href="/">
      <span class="site-brand-orb flex h-10 w-10 items-center justify-center rounded-full text-sm font-semibold text-slate-950">C</span>
      <span class="min-w-0">
        <span class="block font-display text-base tracking-[0.18em] text-white/92 uppercase">CialloClaw</span>
        <span class="block text-xs text-white/52">桌面协作 Agent</span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 lg:flex">
      {PRIMARY_NAV_ITEMS.map((item) => (
        <a class="focus-ring rounded-full px-4 py-2 text-sm text-white/72 transition hover:bg-white/8 hover:text-white" href={resolveHref(item.href)}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <Button asChild radius="full" size="3" highContrast>
        <a href={resolveHref("#download")}>立即下载</a>
      </Button>
    </div>
  </div>
</header>
