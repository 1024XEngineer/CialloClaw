---
export const prerender = true;

import "../../styles/global.css";
import Footer from "@/components/astro/Footer.astro";
import { PixelErhuCursor } from "@/components/interactive/PixelErhuCursor";
import SiteHead from "@/components/layout/SiteHead.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import { Badge, Button, Card, Flex, Heading, Text, Theme } from "@radix-ui/themes";

const docs = [
  {
    id: "architecture-overview",
    title: "架构总览",
    href: "https://github.com/1024XEngineer/CialloClaw/blob/main/docs/architecture-overview.md",
    description: "系统定位、分层边界、task-centric 主链路和治理架构。",
  },
  {
    id: "product-interaction-design",
    title: "产品交互设计",
    href: "https://github.com/1024XEngineer/CialloClaw/blob/main/docs/product-interaction-design.md",
    description: "悬浮球入口、悬停输入、语音承接、文本选中与桌面协作语义。",
  },
  {
    id: "dashboard-design",
    title: "仪表盘设计",
    href: "https://github.com/1024XEngineer/CialloClaw/blob/main/docs/dashboard-design.md",
    description: "仪表盘对任务总览、信任摘要、记忆、安全与可见性的承接方式。",
  },
  {
    id: "control-panel-settings",
    title: "控制面板设置",
    href: "https://github.com/1024XEngineer/CialloClaw/blob/main/docs/control-panel-settings.md",
    description: "Provider、模型、记忆、自动化、悬浮球和预算控制面。",
  },
  {
    id: "protocol-design",
    title: "协议设计",
    href: "https://github.com/1024XEngineer/CialloClaw/blob/main/docs/protocol-design.md",
    description: "正式 JSON-RPC 边界、方法、通知与稳定合同。",
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SiteHead
      title="CialloClaw 文档入口"
      description="CialloClaw 架构、产品、仪表盘、设置与协议真源文档的入口页。"
      path="/docs"
    />
  </head>
  <body>
    <Theme appearance="dark" accentColor="orange" grayColor="mauve" radius="large" scaling="100%">
      <div class="site-shell site-noise">
        <PixelErhuCursor client:load />
        <SiteHeader />
        <main class="section-frame px-4 py-16 lg:px-0 lg:py-24">
          <div class="site-docs-shell">
            <Card className="site-docs-hero rounded-[2.2rem] !p-6 lg:!p-8">
              <Flex direction="column" gap="4">
                <Badge color="cyan" variant="soft" radius="full">文档入口</Badge>
                <Heading size="8">直接阅读指导产品代码库的同一批真源文档。</Heading>
                <Text size="3" color="gray" className="max-w-3xl leading-8">
                  文档页不是重复造一个平行说明站，而是把你引向真正定义产品语言、架构和工程边界的仓库文档。
                  如果首页回答的是“这是什么”，那么这里回答的是“它到底怎么被设计和实现”。
                </Text>
                <div class="flex flex-wrap gap-3">
                  <Button asChild radius="full" size="3" highContrast>
                    <a href="https://github.com/1024XEngineer/CialloClaw">查看仓库</a>
                  </Button>
                  <Button asChild radius="full" size="3" variant="soft">
                    <a href="/">返回首页</a>
                  </Button>
                </div>
              </Flex>
            </Card>

            <div class="site-docs-grid">
              {docs.map((doc) => (
                <a id={doc.id} class="focus-ring" href={doc.href}>
                  <Card className="site-soft-card h-full rounded-[1.75rem] !p-6 transition hover:border-white/16 hover:bg-white/10">
                    <Flex direction="column" gap="3">
                      <Badge color="orange" variant="soft" radius="full">真源文档</Badge>
                      <Heading size="5">{doc.title}</Heading>
                      <Text size="3" color="gray">{doc.description}</Text>
                    </Flex>
                  </Card>
                </a>
              ))}
            </div>
          </div>
        </main>
        <Footer />
      </div>
    </Theme>
  </body>
</html>
